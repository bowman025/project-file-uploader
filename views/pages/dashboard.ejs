<%- include('../partials/header') %>
  <main class="dashboard-page">
    <div class="page-header dashboard-header">
      <h1 class="page-title">Welcome, <%= currentUser.username %>!</h1>
      <form action="/auth/logout" method="POST" class="logout-form">
        <button type="submit" class="btn btn-secondary">Logout</button>
      </form>
    </div>
    <section class="dashboard-section">
      <h3 class="section-title">Storage Usage</h3>
      <% let barColor='#4caf50' ; %>
        <% if (percentUsed> 90) { barColor = '#f44336' %>
          <% } else if (percentUsed> 70) { barColor = '#ff9800'; } %>
            <div class="progress-container">
              <div class="progress-bar" style="--width: <%= percentUsed %>%; --bg-color: <%= barColor %>;"></div>
            </div>
            <p class="section-note">
              <%= usedMB %> MB of 50 MB used
            </p>
    </section>
    <section class="dashboard-section">
      <h3 class="section-title">Create New Folder</h3>
      <%- include('../partials/folderForm') %>
    </section>
    <section class="dashboard-section">
      <h3 class="section-title">Upload an Image</h3>
      <p class="section-note">Allowed: JPG, PNG, GIF, WEBP (Max 5MB)</p>
      <%- include('../partials/fileForm') %>
    </section>
    <section class="dashboard-section">
      <h3 class="section-title">Your Items</h3>
      <h4 class="list-heading">Folders</h4>
      <ul class="folder-list">
        <% if (folders.length===0) { %>
          <li class="empty-state">No folders yet.</li>
          <% } %>
            <% folders.forEach(folder=> { %>
              <li class="folder-item"><a href="/folders/<%= folder.id %>" class="link-button">📁 <%= folder.name %></a>
              </li>
              <% }) %>
      </ul>
      <h4 class="list-heading">Files (Root)</h4>
      <ul class="file-list">
        <% if (files.length===0) { %>
          <li class="empty-state">No files in root.</li>
          <% } %>
            <% files.forEach(file=> { %>
              <li class="file-item">
                <span class="file-name">🖼️ <%= file.displayName %></span>
                <span class="file-meta">(<%= formatBytes(file.size) %>) - <%= formatExactDate(file.uploadedAt) %></span>
                <a href="/files/<%= file.id %>" class="link-button">View Details</a>
              </li>
              <% }) %>
      </ul>
    </section>
  </main>
  <%- include('../partials/footer') %>