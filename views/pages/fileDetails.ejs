<%- include('../partials/header') %>
  <main class="file-details-page">
    <div class="page-header file-header">
      <nav class="breadcrumb-nav">
        <a href="<%= file.folderId ? '/folders/' + file.folderId : '/dashboard' %>" class="link-button">← Back</a>
      </nav>
    </div>
    <h1 class="page-title">Image: <%= file.displayName %>
    </h1>
    <section class="file-details-section">
      <div class="file-preview">
        <% if (file.cloudUrl) { %>
          <img src="<%= file.cloudUrl %>" alt="<%= file.displayName %>" class="file-image">
          <% } else { %>
            <img src="/uploads/<%= file.name %>" alt="<%= file.displayName %>" class="file-image">
            <% } %>
      </div>
      <ul class="file-meta-list">
        <li class="file-meta-item"><strong>Size:</strong>
          <%= formatBytes(file.size) %>
        </li>
        <li class="file-meta-item"><strong>Type:</strong>
          <%= file.mimeType %>
        </li>
        <li class="file-meta-item"><strong>Uploaded:</strong>
          <%= formatExactDate(file.uploadedAt) %>
        </li>
        <li class="file-meta-item"><strong>Location:</strong>
          <%= file.folder ? file.folder.name : 'Root' %>
        </li>
      </ul>
      <div class="action-buttons">
        <a href="/files/<%= file.id %>/download" class="btn btn-primary">Download File</a>
        <a href="/files/<%= file.id %>/confirm-delete" class="btn btn-danger">Delete File</a>
      </div>
    </section>
  </main>
  <%- include('../partials/footer') %>