<%- include('../partials/header') %>
  <header>
    <h1>Log In</h1>
  </header>
  <main>

    <% if (errors && errors.length> 0) { %>
      <ul>
        <% errors.forEach(error=> { %>
          <li>
            <%= error %>
          </li>
          <% }) %>
      </ul>
      <% } %>

        <%- include('../partials/loginForm') %>
          <p>Don't have an account? <a href="/auth/signup">Sign Up</a></p>
  </main>
  <%- include('../partials/footer') %>