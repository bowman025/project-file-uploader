<%- include('../partials/header') %>
  <main class="home-page">
    <% if (currentUser) { %>
      <section class="hero-section">
        <h2 class="section-title">Welcome back, <%= currentUser.username %>!</h2>
        <p class="section-note">Ready to manage your files?</p>
        <div class="action-group">
          <a href="/dashboard" class="btn btn-primary">Go to Dashboard</a>
          <form action="/auth/logout" method="POST" class="inline-form">
            <button type="submit" class="btn btn-secondary">Logout</button>
          </form>
        </div>
      </section>
      <% } else { %>
        <section class="hero-section">
          <h2 class="section-title">Get Started</h2>
          <p class="section-note">Please log in or create an account to start uploading images.</p>
          <div class="action-group">
            <a href="/auth/login" class="btn btn-primary">Log In</a>
            <a href="/auth/signup" class="btn btn-secondary">Sign Up</a>
          </div>
        </section>
        <% } %>
  </main>
  <%- include('../partials/footer') %>