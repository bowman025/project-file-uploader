<%- include('../partials/header') %>
  <main class="auth-page">
    <div class="page-header auth-header">
      <h1 class="page-title">Sign Up</h1>
    </div>
    <% if (errors && errors.length> 0) { %>
      <ul class="error-list">
        <% errors.forEach(error=> { %>
          <li class="error-item">
            <%= error.msg || error %>
          </li>
          <% }) %>
      </ul>
      <% } %>
        <%- include('../partials/signupForm') %>
          <p class="auth-prompt">Already have an account? <a href="/auth/login" class="link-button">Log In</a></p>
  </main>
  <%- include('../partials/footer') %>