<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>
    <%= title %>
  </title>
</head>

<body>
  <nav>
    <a href="/dashboard">← Back to Dashboard</a>
  </nav>

  <h1>📁 Folder: <%= folder.name %>
  </h1>
  <p>Created on: <%= formatExactDate(folder.createdAt) %>
  </p>

  <hr>

  <section>
    <h3>Upload an Image to this Folder</h3>
    <form action="/files/upload" method="POST" enctype="multipart/form-data">
      <input type="file" name="file" required>
      <input type="hidden" name="folderId" value="<%= folder.id %>">
      <button type="submit">Upload to <%= folder.name %></button>
    </form>
  </section>

  <hr>

  <section>
    <h3>Files in this Folder</h3>
    <ul>
      <% if (files.length===0) { %>
        <li>This folder is empty.</li>
        <% } %>
          <% files.forEach(file=> { %>
            <li>
              🖼️ <%= file.displayName %>
                (<%= (Number(file.size) / 1024).toFixed(2) %> KB) -
                  <%= formatExactDate(file.uploadedAt) %>
                    <a href="/files/<%= file.id %>">View Details</a>
            </li>
            <% }); %>
    </ul>
  </section>

</body>

</html>