<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>
    <%= title %>
  </title>
</head>

<body>
  <nav>
    <a href="/dashboard">← Back to Dashboard</a>
  </nav>

  <h1>📁 Folder: <%= folder.name %>
  </h1>
  <p>Created on: <%= formatExactDate(folder.createdAt) %>
  </p>

  <div style="margin: 20px 0;">
    <a href="/folders/<%= folder.id %>/confirm-delete" style="color: red; text-decoration: none;">
      <button type="button" style="color: red;">Delete Folder</button>
    </a>
  </div>

  <hr>

  <section>
    <h3>Upload an Image to this Folder</h3>
    <form action="/files/upload" method="POST" enctype="multipart/form-data">
      <input type="file" name="file" required>
      <input type="hidden" name="folderId" value="<%= folder.id %>">
      <button type="submit">Upload to <%= folder.name %></button>
    </form>
  </section>

  <hr>

  <section>
    <h3>Share this Folder</h3>
    <form action="/share/create" method="POST">
      <input type="hidden" name="folderId" value="<%= folder.id %>">
      <select name="duration">
        <option value="1">1 Day</option>
        <option value="7">7 Days</option>
        <option value="30">30 Days</option>
      </select>
      <button type="submit">Generate Share Link</button>
    </form>

    <% if (shareId) { %>
      <p>Share this URL: <code><%= origin %>/share/<%= shareId %></code></p>
      <% } %>
  </section>

  <section>
    <h3>Active Share Links</h3>
    <% if (activeShares.length> 0) { %>
      <ul>
        <% activeShares.forEach(share=> { %>
          <li>
            <strong>URL:</strong>
            <code><%= origin %>/share/<%= share.id %></code>
            <br>
          </li>
          <% }) %>
      </ul>
      <% } else { %>
        <p>No active public links for this folder.</p>
        <% } %>
  </section>


  <hr>

  <section>
    <h3>Files in this Folder</h3>
    <ul>
      <% if (files.length===0) { %>
        <li>This folder is empty.</li>
        <% } %>
          <% files.forEach(file=> { %>
            <li>
              🖼️ <%= file.displayName %>
                (<%= (Number(file.size) / 1024).toFixed(2) %> KB) -
                  <%= formatExactDate(file.uploadedAt) %>
                    <a href="/files/<%= file.id %>">View Details</a>
            </li>
            <% }); %>
    </ul>
  </section>

</body>

</html>