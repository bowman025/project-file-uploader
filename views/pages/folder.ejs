<%- include('../partials/header') %>
  <main class="folder-page">
    <div class="page-header folder-header">
      <nav class="breadcrumb-nav">
        <a href="/dashboard" class="link-button">← Back to Dashboard</a>
      </nav>
    </div>
    <h1 class="page-title">📁 Folder: <%= folder.name %>
    </h1>
    <p class="folder-meta">Created on: <%= formatExactDate(folder.createdAt) %>
    </p>
    <div class="folder-actions">
      <a href="/folders/<%= folder.id %>/confirm-delete" class="btn btn-danger">Delete Folder</a>
    </div>
    <section class="upload-section">
      <h3 class="section-title">Upload an Image to this Folder</h3>
      <form action="/files/upload" method="POST" enctype="multipart/form-data" class="upload-form">
        <input type="file" name="file" class="form-input" required>
        <input type="hidden" name="folderId" value="<%= folder.id %>">
        <button type="submit" class="btn btn-primary">Upload to <%= folder.name %></button>
      </form>
    </section>
    <section class="share-section">
      <h3 class="section-title">Share this Folder</h3>
      <form action="/share/create" method="POST" class="share-form">
        <input type="hidden" name="folderId" value="<%= folder.id %>">
        <select name="duration" class="form-select">
          <option value="1">1 Day</option>
          <option value="7">7 Days</option>
          <option value="30">30 Days</option>
        </select>
        <button type="submit" class="btn btn-primary">Generate Share Link</button>
      </form>
    </section>
    <% if (activeShares.length> 0) { %>
      <section class="share-list-section">
        <h3 class="section-title">Active Share Links</h3>
        <ul class="share-list">
          <% activeShares.forEach(share=> { %>
            <li class="share-item">
              <span>
                <strong>URL:</strong>
                <code><%= origin %>/share/<%= share.id %></code>
              </span>
              <p class="share-expiry">Valid until: <%= formatExactDate(share.expiresAt) %>
              </p>
            </li>
            <% }) %>
        </ul>
      </section>
      <% } %>
        <section class="folder-files-section">
          <h3 class="section-title">Files in this Folder</h3>
          <ul class="file-list">
            <% if (folder.files.length===0) { %>
              <li class="empty-state">This folder is empty.</li>
              <% } %>
                <% folder.files.forEach(file=> { %>
                  <li class="file-item">
                    <span class="file-name">🖼️ <%= file.displayName %></span>
                    <span class="file-meta">(<%= formatBytes(file.size) %>) - <%= formatExactDate(file.uploadedAt) %>
                    </span>
                    <a href="/files/<%= file.id %>" class="link-button">View Details</a>
                  </li>
                  <% }); %>
          </ul>
        </section>
  </main>
  <%- include('../partials/footer') %>