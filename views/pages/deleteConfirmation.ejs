<%- include('../partials/header') %>
  <header>
    <nav>
      <a href="/files/<%= file.id %>">← Back to File</a>
    </nav>
  </header>
  <main>

    <h1>Delete File</h1>

    <div>
      <p>Are you sure you want to permanently delete this file?</p>

      <div>
        <strong>
          <%= file.displayName %>
        </strong><br>
        Size: <%= formatBytes(file.size) %><br>
          Type: <%= file.mimeType %>
      </div>

      <div>
        ⚠️ This action cannot be undone!
      </div>
    </div>

    <div>
      <form action="/files/<%= file.id %>/delete" method="POST">
        <button type="submit">
          Yes, Delete File
        </button>
      </form>

      <a href="/files/<%= file.id %>">
        <button type="button">
          Cancel
        </button>
      </a>
    </div>
  </main>
  <%- include('../partials/footer') %>