<%- include('../partials/header') %>
  <main class="confirm-page">
    <div class="page-header confirm-header">
      <nav class="breadcrumb-nav">
        <a href="/files/<%= file.id %>" class="link-button">← Back to File</a>
      </nav>
    </div>
    <h1 class="page-title">Delete File</h1>
    <div class="confirm-card">
      <p class="confirm-message">Are you sure you want to permanently delete this file?</p>

      <div class="confirm-details">
        <strong class="confirm-file-name">
          <%= file.displayName %>
        </strong><br>
        Size: <%= formatBytes(file.size) %><br>
          Type: <%= file.mimeType %>
      </div>

      <div class="warning-text">
        ⚠️ This action cannot be undone!
      </div>
    </div>

    <div class="confirm-actions">
      <form action="/files/<%= file.id %>/delete" method="POST" class="confirm-form">
        <button type="submit" class="btn btn-danger">Yes, Delete File</button>
      </form>

      <a href="/files/<%= file.id %>" class="btn btn-secondary">Cancel</a>
    </div>
  </main>
  <%- include('../partials/footer') %>