<%- include('../partials/header') %>
  <main class="confirm-page">
    <div class="page-header confirm-header">
      <nav class="breadcrumb-nav">
        <a href="/folders/<%= folder.id %>" class="link-button">← Back to Folder</a>
      </nav>
    </div>
    <h1 class="page-title">Delete Folder</h1>
    <div class="confirm-card">
      <p class="confirm-message">Are you sure you want to permanently delete this folder and all its contents?</p>

      <div class="confirm-details">
        <strong>📁 <%= folder.name %></strong><br>
        Created: <%= formatExactDate(folder.createdAt) %><br>
          Files: <%= fileCount %>
      </div>

      <% if (fileCount> 0) { %>
        <div class="warning-text">
          ⚠️ This folder contains <%= fileCount %> file<%= fileCount===1 ? '' : 's' %> that will also be deleted!
        </div>
        <% } %>

          <div class="warning-text">
            ⚠️ This action cannot be undone!
          </div>
    </div>
    <div class="confirm-actions">
      <form action="/folders/<%= folder.id %>/delete" method="POST" class="confirm-form">
        <button type="submit" class="btn btn-danger">
          Yes, Delete Folder<%= fileCount> 0 ? ' and Files' : '' %>
        </button>
      </form>

      <a href="/folders/<%= folder.id %>" class="btn btn-secondary">Cancel</a>
    </div>
  </main>
  <%- include('../partials/footer') %>