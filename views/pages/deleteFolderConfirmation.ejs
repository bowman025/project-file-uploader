<%- include('../partials/header') %>
  <header>
    <nav>
      <a href="/folders/<%= folder.id %>">← Back to Folder</a>
    </nav>
  </header>
  <main>

    <h1>Delete Folder</h1>

    <div>
      <p>Are you sure you want to permanently delete this folder and all its contents?</p>

      <div>
        <strong>📁 <%= folder.name %></strong><br>
        Created: <%= formatExactDate(folder.createdAt) %><br>
          Files: <%= fileCount %>
      </div>

      <% if (fileCount> 0) { %>
        <div>
          ⚠️ This folder contains <%= fileCount %> file<%= fileCount===1 ? '' : 's' %> that will also be deleted!
        </div>
        <% } %>

          <div>
            ⚠️ This action cannot be undone!
          </div>
    </div>

    <div>
      <form action="/folders/<%= folder.id %>/delete" method="POST">
        <button type="submit">
          Yes, Delete Folder<%= fileCount> 0 ? ' and Files' : '' %>
        </button>
      </form>

      <a href="/folders/<%= folder.id %>">
        <button type="button">
          Cancel
        </button>
      </a>
    </div>
  </main>
  <%- include('../partials/footer') %>